{
  "expo": {
    "name": "Docuflash",
    "slug": "docuflash-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "docuflashmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.novodip.docuflashmobile",
      "buildNumber": "1",
      "icon": "./assets/images/icon.png",
      "associatedDomains": ["applinks:docuflash-frontend.vercel.app"]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "versionCode": 1,
      "predictiveBackGestureEnabled": false,
      "package": "com.novodip.docuflashmobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "docuflash-frontend.vercel.app",
              "pathPrefix": "/share"
            },
            {
              "scheme": "https",
              "host": "docuflash-frontend.vercel.app",
              "pathPrefix": "/folder"
            }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon-192.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/icon.png",
          "imageWidth": 180
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      "expo-mail-composer",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REPLACE_WITH_REVERSED_IOS_CLIENT_ID"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Docuflash to access your photos to set a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7b366d99-ded1-476e-a8a2-aa89420c8f4f"
      }
    },
    "owner": "novodip"
  }
}
