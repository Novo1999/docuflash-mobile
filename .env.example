# Backend REST + UploadThing host (same host the web app's NEXT_PUBLIC_BASE_URL points at).
# Production:
EXPO_PUBLIC_BASE_URL=https://docuflash-api.vercel.app
# Local backend from a real device/simulator — use your machine's LAN IP, NOT localhost:
# EXPO_PUBLIC_BASE_URL=http://192.168.1.50:8000

# Where share links resolve (the web frontend host). Optional — defaults to the deployed web app.
EXPO_PUBLIC_SHARE_BASE_URL=https://docuflash-frontend.vercel.app

# Supabase — used for realtime broadcast on "Request files" upload pages (same project as the backend).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Native Google Sign-In (@react-native-google-signin/google-signin) — requires a custom dev build.
# "Web client" OAuth client ID from Google Cloud console — needed to receive an idToken.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# "iOS client" OAuth client ID (iOS only). The reversed form also goes in app.json's iosUrlScheme.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
