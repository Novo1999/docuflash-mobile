# Backend REST + UploadThing host (same host the web app's NEXT_PUBLIC_BASE_URL points at).
# Production:
EXPO_PUBLIC_BASE_URL=https://docuflash-api.vercel.app
# Local backend from a real device/simulator — use your machine's LAN IP, NOT localhost:
# EXPO_PUBLIC_BASE_URL=http://192.168.1.50:8000

# Where share links resolve (the web frontend host). Optional — defaults to the deployed web app.
EXPO_PUBLIC_SHARE_BASE_URL=https://docuflash-frontend.vercel.app
