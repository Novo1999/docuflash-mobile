{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.13.0",
      "env": {
        "EAS_USE_CACHE": "1",
        "EXPO_PUBLIC_BASE_URL": "https://docuflash-api.vercel.app",
        "EXPO_PUBLIC_SHARE_BASE_URL": "https://docuflash-frontend.vercel.app",
        "EAS_GRADLE_CACHE": "1"
      }
    },
    "development": {
      "extends": "base",
      "distribution": "internal",
      "environment": "development",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true
    }
  }
}
